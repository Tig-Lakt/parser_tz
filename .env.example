# База данных
DB_HOST=db
DB_PORT=5432
DB_NAME=parser
DB_USER=postgres
DB_PASSWORD=postgres
DB_ECHO=false

# Парсер
CHROME_VERSION=145
CHROME_HEADLESS=true
DELAY_BETWEEN_CASES=2.0
DELAY_BETWEEN_INNS=1.5
MAX_CONCURRENT_INNS=3
MAX_RETRIES=3
RETRY_BASE_DELAY=2

# Логирование
LOG_LEVEL=INFO
LOG_FILE=logs/parser.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5